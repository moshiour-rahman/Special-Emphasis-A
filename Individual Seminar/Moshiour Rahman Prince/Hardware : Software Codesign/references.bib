}

@article{camposano1990,
  author  = {Camposano, R.},
  title   = {From Behavior to Structure: High-Level Synthesis},
  journal = {IEEE Design \& Test of Computers},
  volume  = {7},
  number  = {5},
  pages   = {8--19},
  year    = {1990},
  doi     = {10.1109/54.60603},
  annote  = {Classic behavioral-to-structural HLS reference; underlies the paper's decision to carry the flow all the way to a synthesizable VHDL RTL netlist (Sec. V) rather than stop at a scheduled software model.}
}

@article{arato2005,
  author  = {Arat{\'o}, P. and Mann, Z. {\'A}. and Orb{\'a}n, A.},
  title   = {Algorithmic Aspects of Hardware/Software Partitioning},
  journal = {ACM Transactions on Design Automation of Electronic Systems},
  volume  = {10},
  number  = {1},
  pages   = {136--156},
  year    = {2005},
