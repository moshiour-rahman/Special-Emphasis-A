  annote  = {Connects scheduling decisions to the broader hardware/software co-design problem; cited in the Introduction to frame the seminar's HW/SW Codesign context and again in the Conclusion as the basis for the proposed future-work direction (mapping timing-critical tasks to hardware while the GA search stays in software).}
}

@article{hwang1991,
  author  = {Hwang, C.-T. and Lee, J.-H. and Hsu, Y.-C.},
  title   = {A Formal Approach to the Scheduling Problem in High-Level Synthesis},
  journal = {IEEE Transactions on Computer-Aided Design},
  volume  = {10},
  number  = {4},
  pages   = {464--475},
  year    = {1991},
  doi     = {10.1109/43.75629},
  annote  = {Supplies the formal ILP scheduling model and the NP-hardness proof for resource-constrained scheduling that directly justifies replacing exact/greedy methods with a genetic-algorithm heuristic in this paper (Sec. I-B, III-C, and the precedence constraint of Eq. 3).}
}

@article{paulin1989,
  author  = {Paulin, P. G. and Knight, J. P.},
  title   = {Force-Directed Scheduling for the Behavioral Synthesis of ASICs},
  journal = {IEEE Transactions on Computer-Aided Design},
  volume  = {8},
  number  = {6},
  pages   = {661--679},
  year    = {1989},
  doi     = {10.1109/43.31522},
  annote  = {Serves as the deterministic, single-trajectory constructive-heuristic baseline against which the GA's population-based search is contrasted (Sec. I-C and Related Work); also the source of the ASAP/ALAP mobility-window concept used to bound the chromosome genes (Sec. III-B, IV-C).}
}

@book{holland1975,
  author    = {Holland, J. H.},
  title     = {Adaptation in Natural and Artificial Systems},
  publisher = {University of Michigan Press},
  address   = {Ann Arbor, MI},
  year      = {1975},
  annote    = {Foundational reference for genetic algorithms; grounds the selection/crossover/mutation search engine (Sec. III-D) that the paper applies to traffic-controller scheduling.}
}

@book{goldberg1989,
  author    = {Goldberg, D. E.},
  title     = {Genetic Algorithms in Search, Optimization, and Machine Learning},
  publisher = {Addison-Wesley},
  address   = {Reading, MA},
  year      = {1989},
  annote    = {Standard GA reference used specifically for the penalty-based fitness construction (Eqs. 7-8, Sec. III-E) that turns the constrained scheduling problem into an unconstrained fitness-maximization problem.}
}

@inproceedings{arato2002,
