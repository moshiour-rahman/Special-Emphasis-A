
@article{spuri1996,
  author    = {Spuri, Marco and Buttazzo, Giorgio C.},
  title     = {Scheduling Aperiodic Tasks in Dynamic Priority Systems},
  journal   = {Real-Time Systems},
  volume    = {10},
  number    = {2},
  pages     = {179--210},
  year      = {1996},
  publisher = {Springer},
  doi       = {10.1007/BF00360340},
  relevance = {This is the foundational paper that introduces the Total Bandwidth Server (TBS) for servicing soft aperiodic requests in EDF-scheduled systems. It defines the synthetic-deadline rule d_k = max(r_k, d_{k-1}) + C_k/U_s and proves that a periodic set with utilization U_p plus a server of bandwidth U_s remains schedulable under EDF iff U_p + U_s <= 1. The present seminar paper takes TBS as its central subject: the deadline rule (Eq. 3), the schedulability theorem (Theorem 1), and the O(1) overhead analysis are all drawn directly from this source and then reproduced and verified in the UPPAAL model.}
}

@book{buttazzo2011,
  author    = {Buttazzo, Giorgio C.},
  title     = {Hard Real-Time Computing Systems: Predictable Scheduling Algorithms and Applications},
  edition   = {3},
  publisher = {Springer},
  address   = {New York},
  year      = {2011},
  isbn      = {978-1-4614-0675-4},
  doi       = {10.1007/978-1-4614-0676-1},
  relevance = {This standard graduate textbook gives the systematic treatment of real-time scheduling: the definition of real-time correctness, the periodic/aperiodic task model, background scheduling, fixed bandwidth reservation, and the family of aperiodic servers. The seminar paper relies on it for the foundational definitions in the Introduction and Background sections, including the notion that aperiodic deadlines generally cannot be guaranteed and that naive background service yields unbounded response times. It supplies the conceptual framing against which TBS is presented as an improvement.}
}

@book{kopetz2011,
  author    = {Kopetz, Hermann},
  title     = {Real-Time Systems: Design Principles for Distributed Embedded Applications},
  edition   = {2},
  publisher = {Springer},
  address   = {New York},
  year      = {2011},
  isbn      = {978-1-4419-8236-0},
  doi       = {10.1007/978-1-4419-8237-7},
  relevance = {This widely cited textbook lays out the design principles of real-time systems, defining real-time correctness as dependence on both the value and the instant a result is produced, and emphasizing temporal predictability for safety-critical distributed embedded applications such as automotive and avionics control. The seminar paper cites it as a foundational source for the definition of real-time systems and the hard/soft distinction in the Introduction. It is also cited in the Limitations discussion to support the point that distributed deployments of TBS require additional mechanisms for end-to-end deadlines and jitter across nodes, which is the book's central focus.}
}

@article{liu1973,
  author    = {Liu, C. L. and Layland, James W.},
  title     = {Scheduling Algorithms for Multiprogramming in a Hard-Real-Time Environment},
  journal   = {Journal of the ACM},
  volume    = {20},
  number    = {1},
  pages     = {46--61},
  year      = {1973},
  publisher = {Association for Computing Machinery},
  doi       = {10.1145/321738.321743},
  relevance = {This classic paper establishes the two pillars of uniprocessor real-time scheduling: the Rate Monotonic (RM) fixed-priority algorithm with its ln 2 ~ 69.3% utilization bound, and the Earliest Deadline First (EDF) dynamic-priority algorithm, which can achieve full processor utilization (U_p <= 1). The seminar paper cites it for the periodic task model, the EDF schedulability condition (Eq. 1), and the comparison between EDF and RM utilization bounds. EDF is the scheduling framework within which TBS operates, so this reference underpins the entire analysis.}
}

@inproceedings{fohler2001,
  author    = {Fohler, Gerhard and Lennvall, Tomas and Buttazzo, Giorgio},
  title     = {Improved Handling of Soft Aperiodic Tasks in Offline Scheduled Real-Time Systems Using Total Bandwidth Server},
  booktitle = {Proc. 8th IEEE Int. Conf. on Emerging Technologies and Factory Automation (ETFA)},
  volume    = {1},
  pages     = {151--157},
  address   = {Antibes Juan-les-Pins, France},
  month     = oct,
  year      = {2001},
  publisher = {IEEE},
  doi       = {10.1109/ETFA.2001.996364},
  relevance = {This paper extends the Total Bandwidth Server to offline (table-driven) and distributed scheduling settings, addressing how soft aperiodic tasks can be served on top of precomputed static schedules while respecting end-to-end constraints. The seminar paper cites it in the Limitations and Conclusion sections to acknowledge that TBS in its original form assumes a known WCET at arrival and handles only soft aperiodics, and to motivate future extensions toward distributed systems with precedence and jitter constraints. It situates TBS within a broader applicability landscape.}
}

@article{david2015,
  author    = {David, Alexandre and Larsen, Kim G. and Legay, Axel and Miku\v{c}ionis, Marius and Poulsen, Danny B{\o}gsted},
  title     = {{UPPAAL SMC} Tutorial},
  journal   = {International Journal on Software Tools for Technology Transfer},
  volume    = {17},
  number    = {4},
  pages     = {397--415},
  year      = {2015},
  publisher = {Springer},
  doi       = {10.1007/s10009-014-0361-y},
  relevance = {This tutorial surveys UPPAAL and its statistical model checking extension, covering the modeling of networks of timed automata, the query language, and verification workflow for real-time systems. The seminar paper cites it as the practical reference for the UPPAAL toolset used to build and verify the TBS model. It supports the modeling methodology (templates, clocks, broadcast channels) and the TCTL-style verification queries that establish deadlock-freedom and schedulability of the implemented model.}
}

