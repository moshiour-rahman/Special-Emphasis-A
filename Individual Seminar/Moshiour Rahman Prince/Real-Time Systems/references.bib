@inproceedings{larsen1997,
  author    = {Larsen, Kim G. and Pettersson, Paul and Yi, Wang},
  title     = {{UPPAAL} in a Nutshell},
  journal   = {International Journal on Software Tools for Technology Transfer},
  volume    = {1},
  number    = {1-2},
  pages     = {134--152},
  year      = {1997},
  publisher = {Springer},
  doi       = {10.1007/s100090050010},
  relevance = {This is the original presentation of the UPPAAL model checker for networks of timed automata, describing its symbolic model-checking engine, location/clock/channel semantics, and graphical modeling environment. The seminar paper's model uses standard (non-stochastic) UPPAAL timed automata, so this is the primary tool reference for the verification approach. It justifies the choice of timed automata with committed locations, integer variables, and broadcast synchronization to encode the discrete-time EDF scheduler and the TBS deadline assignment.}
}

@article{alur1994,
  author    = {Alur, Rajeev and Dill, David L.},
  title     = {A Theory of Timed Automata},
  journal   = {Theoretical Computer Science},
  volume    = {126},
  number    = {2},
  pages     = {183--235},
  year      = {1994},
  publisher = {Elsevier},
  doi       = {10.1016/0304-3975(94)90010-8},
  relevance = {This paper defines the formal model of timed automata: finite automata augmented with real-valued clocks, clock constraints on transitions, and location invariants, providing the theoretical basis for modeling and verifying real-time systems. The seminar paper cites it as the formalism underlying the UPPAAL model, in which the PeriodicGenerator, AperiodicGenerator, and Scheduler are expressed as a network of timed automata. It grounds the claim that re-evaluating the EDF decision at every integer instant reproduces the exact continuous-time preemptive schedule.}
}

@article{alur1993,
  author    = {Alur, Rajeev and Courcoubetis, Costas and Dill, David L.},
  title     = {Model-Checking in Dense Real-Time},
  journal   = {Information and Computation},
  volume    = {104},
  number    = {1},
  pages     = {2--34},
  year      = {1993},
  publisher = {Elsevier},
  doi       = {10.1006/inco.1993.1024},
  relevance = {This paper introduces Timed Computation Tree Logic (TCTL) and shows that model checking of timed automata against TCTL specifications is decidable via the region-graph construction. The seminar paper cites it as the logical basis for the seven TCTL verification queries discharged by the UPPAAL verifier, which check deadlock-freedom, the no-missed-deadline (schedulability) property, and the correctness of the assigned synthetic deadlines. It legitimizes the use of temporal-logic queries to certify properties of the TBS model over the whole observation window.}
}

@article{sprunt1989,
  author    = {Sprunt, Brinkley and Sha, Lui and Lehoczky, John P.},
  title     = {Aperiodic Task Scheduling for Hard-Real-Time Systems},
  journal   = {Real-Time Systems},
  volume    = {1},
  number    = {1},
  pages     = {27--60},
  year      = {1989},
  publisher = {Springer},
  doi       = {10.1007/BF02341920},
  relevance = {This paper introduces the Sporadic Server, a fixed-priority aperiodic server that preserves a replenishment budget and improves aperiodic response times while guaranteeing periodic deadlines. The seminar paper cites it when contrasting TBS with more complex servers that require a replenishment timer and queue, highlighting that TBS needs only a single stored deadline value and O(1) work per arrival. It provides the point of comparison for the runtime-overhead and memory-efficiency argument in favor of TBS.}
}

@article{strosnider1995,
  author    = {Strosnider, Jay K. and Lehoczky, John P. and Sha, Lui},
  title     = {The Deferrable Server Algorithm for Enhanced Aperiodic Responsiveness in Hard Real-Time Environments},
  journal   = {IEEE Transactions on Computers},
  volume    = {44},
  number    = {1},
  pages     = {73--91},
  year      = {1995},
  publisher = {IEEE},
  doi       = {10.1109/12.368008},
  relevance = {This paper presents the Deferrable Server (and analyzes it against the simpler Polling Server) for improving aperiodic responsiveness under fixed-priority scheduling by preserving server capacity until an aperiodic request arrives. The seminar paper cites it when noting that, unlike the Polling and Deferrable Servers, TBS never wastes reserved bandwidth when no aperiodic requests are present, since unused capacity flows automatically to the periodic task set. It supplies the baseline server behavior that TBS improves upon in terms of bandwidth utilization.}
}

@inproceedings{spuri1994,
  author    = {Spuri, Marco and Buttazzo, Giorgio C.},
  title     = {Efficient Aperiodic Service Under Earliest Deadline Scheduling},
  booktitle = {Proc. IEEE Real-Time Systems Symposium (RTSS)},
  pages     = {2--11},
  address   = {San Juan, Puerto Rico},
  month     = dec,
  year      = {1994},
  publisher = {IEEE Computer Society Press},
  doi       = {10.1109/REAL.1994.342735},
  relevance = {This paper presents a family of EDF-based aperiodic servers (including dynamic versions such as the Priority Exchange server and the EDL server) that trade efficiency against implementation complexity. The seminar paper cites it as the dynamic-priority counterpart to the Priority Exchange server mentioned alongside the Sporadic Server, and as a representative of more elaborate EDF aperiodic servers against which the simplicity of TBS is contrasted. It frames TBS as the lightweight extreme of the EDF aperiodic-server design space.}
}

@inproceedings{abeni1998,
  author    = {Abeni, Luca and Buttazzo, Giorgio},
  title     = {Integrating Multimedia Applications in Hard Real-Time Systems},
  booktitle = {Proc. 19th IEEE Real-Time Systems Symposium (RTSS)},
  pages     = {4--13},
  address   = {Madrid, Spain},
  month     = dec,
  year      = {1998},
  publisher = {IEEE Computer Society},
  doi       = {10.1109/REAL.1998.739726},
  relevance = {This paper introduces the Total Bandwidth Server(TBS),an EDF-based reservation mechanism that enforces temporal isolation by capping each served task at a predefined bandwidth, using a budget-and-deadline-postponement rule. The seminar paper cites it in the Conclusion as the natural successor and comparison point to TBS, proposing that future work compare TBS empirically against the CBS. It represents the bandwidth-reservation lineage that grew out of the TBS idea.}
}
